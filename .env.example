# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# ===== Source Postgres (OLTP device registry) =====
SOURCE_POSTGRES_USER=iot_app
SOURCE_POSTGRES_PASSWORD=changeme
SOURCE_POSTGRES_DB=iot_registry
SOURCE_POSTGRES_PORT=5432

# ===== Warehouse Postgres =====
WAREHOUSE_POSTGRES_USER=warehouse
WAREHOUSE_POSTGRES_PASSWORD=changeme
WAREHOUSE_POSTGRES_DB=iot_warehouse
WAREHOUSE_POSTGRES_PORT=5433

# ===== Kafka =====
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ===== MinIO (S3-compatible object storage) =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET=raw-telemetry
